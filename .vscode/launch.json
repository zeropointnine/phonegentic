    "version": "0.2.0",
    "configurations": [
        {
            "name": "phonegentic",
            "cwd": "phonegentic",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=ENABLE_ON_DEVICE_MODELS=true"
            ]
        },
        {
            "name": "phonegentic (lite, no on-device models)",
            "cwd": "phonegentic",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "phonegentic (profile mode)",
            "cwd": "phonegentic",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": [
                "--dart-define=ENABLE_ON_DEVICE_MODELS=true"
            ]
        },
        {
            "name": "phonegentic (release mode)",
            "cwd": "phonegentic",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--dart-define=ENABLE_ON_DEVICE_MODELS=true"
            ]
        }
    ]
}