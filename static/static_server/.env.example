# At least one of these must be set for SMS forms to email via sendmail:
# SMS_OPTIN_NOTIFY_EMAIL=your-address@example.com
# — or a single shared inbox for both subscribe and unsubscribe:
# SMS_NOTIFY_EMAIL=your-address@example.com

# Optional: opt-out only (otherwise uses SMS_NOTIFY_EMAIL or SMS_OPTIN_NOTIFY_EMAIL)
# SMS_OPTOUT_NOTIFY_EMAIL=your-address@example.com

# Optional: From header for sendmail (default: Phonegentic <noreply@phonegentic.ai>)
# SMS_OPTIN_MAIL_FROM=Phonegentic <noreply@phonegentic.ai>
# SMS_MAIL_FROM=Phonegentic <noreply@phonegentic.ai>

# Optional: override static file root (default: /var/html)
# WEB_ROOT=/var/html
