# ── Email delivery ──────────────────────────────────────────────
# When SENDGRID_API_KEY is set, emails are sent via Twilio SendGrid.
# Otherwise falls back to local sendmail, then to file logging.
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# At least one of these must be set for email notifications:
# SMS_OPTIN_NOTIFY_EMAIL=your-address@example.com
# — or a single shared inbox for both subscribe and unsubscribe:
# SMS_NOTIFY_EMAIL=your-address@example.com

# Optional: opt-out only (otherwise uses SMS_NOTIFY_EMAIL or SMS_OPTIN_NOTIFY_EMAIL)
# SMS_OPTOUT_NOTIFY_EMAIL=your-address@example.com

# Optional: help form notifications (otherwise uses SMS_NOTIFY_EMAIL)
# HELP_NOTIFY_EMAIL=your-address@example.com

# Optional: From header (default: Phonegentic <noreply@phonegentic.ai>)
# SMS_OPTIN_MAIL_FROM=Phonegentic <noreply@phonegentic.ai>
# SMS_MAIL_FROM=Phonegentic <noreply@phonegentic.ai>

# Optional: override static file root (default: /var/html)
# WEB_ROOT=/var/html
